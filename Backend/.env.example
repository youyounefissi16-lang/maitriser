MONGODB_URI=mongodb://localhost:27017/quizapp
JWT_SECRET=change_this_to_a_long_random_string_in_production
CLERK_SECRET_KEY=sk_live_<your-clerk-secret-key>
ADMIN_SECRET_CODE=<your-admin-secret-code>
PORT=4000

# Comma-separated list of allowed frontend origins (no trailing slash)
# For production, set to your deployed frontend URLs:
#   CORS_ORIGIN=https://quizapp.example.com,https://admin.quizapp.example.com
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Set NODE_ENV=production to enable HSTS (2-year) and disable stack traces in errors
# NODE_ENV=production

# SMTP (optional — only needed for email verification / password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
GMAIL_USER=
GMAIL_PASS=
EMAIL_FROM=noreply@quizapp.local
